{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      },
      "workspace": "/mnt/claw-data/workspace",
      "maxConcurrent": 4,
      "sandbox": {
        "mode": "off"
      },
      "elevatedDefault": "full",
      "thinkingDefault": "high",
      "subagents": {
        "model": "xai/grok-4.20-0309-reasoning",
        "maxConcurrent": 4,
        "maxSpawnDepth": 5,
        "maxChildrenPerAgent": 20
      }
    },
    "list": [
      {
        "id": "main",
        "default": true
      }
    ]
  },

  "models": {
    "mode": "merge",
    "providers": {
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "grok-4.20-0309-reasoning",
            "name": "Grok 4 Reasoning",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 200000
          },
          {
            "id": "grok-4",
            "name": "Grok 4",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 200000
          },
          {
            "id": "grok-2-vision-1212",
            "name": "Grok 2 Vision",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 32768,
            "maxTokens": 32768
          }
        ]
      },
      "moonshot": {
        "baseUrl": "https://api.moonshot.ai/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 262144,
            "maxTokens": 262144
          }
        ]
      },
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 32000
          },
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 32000
          }
        ]
      },
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek V3",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 128000
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek R1",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 128000
          }
        ]
      }
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "disabled",
      "streaming": {
        "mode": "partial"
      }
    }
  },

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "tailscale": {
      "mode": "off"
    }
  },

  "tools": {
    "exec": {
      "security": "full",
      "ask": "off",
      "backgroundMs": 10000,
      "timeoutSec": 1800
    },
    "web": {
      "search": { "enabled": true },
      "fetch": { "enabled": true }
    }
  },

  "browser": {
    "enabled": true,
    "executablePath": "/usr/bin/google-chrome-stable",
    "headless": false,
    "noSandbox": true
  },

  "logging": {
    "redactSensitive": "tools"
  }
}
