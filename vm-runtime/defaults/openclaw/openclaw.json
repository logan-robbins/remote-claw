{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "workspace": "/mnt/claw-data/workspace",
      "maxConcurrent": 4,
      "sandbox": {
        "mode": "off"
      },
      "elevatedDefault": "full",
      "thinkingDefault": "high",
      "skills": [
        "/mnt/claw-data/workspace/skills"
      ],
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "heartbeat": {
        "every": "30m"
      },
      "subagents": {
        "allowAgents": [
          "*"
        ],
        "maxSpawnDepth": 1,
        "maxChildrenPerAgent": 10
      },
      "models": {
        "anthropic/claude-opus-4-6": {
          "params": {
            "cacheRetention": "short"
          },
          "alias": "opus"
        }
      },
      "compaction": {
        "mode": "safeguard"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "grok-4",
            "name": "Grok 4",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 1000000,
            "maxTokens": 32000
          },
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 1000000,
            "maxTokens": 32000
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "groupPolicy": "disabled",
      "streaming": {
        "mode": "partial"
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token"
    }
  },
  "tools": {
    "exec": {
      "security": "full",
      "ask": "off",
      "backgroundMs": 10000,
      "timeoutSec": 1800
    },
    "web": {
      "search": {
        "enabled": true
      },
      "fetch": {
        "enabled": true
      }
    },
    "loopDetection": {
      "enabled": true,
      "historySize": 30,
      "warningThreshold": 10,
      "criticalThreshold": 20,
      "globalCircuitBreakerThreshold": 30,
      "detectors": {
        "genericRepeat": true,
        "knownPollNoProgress": true,
        "pingPong": true
      }
    }
  },
  "browser": {
    "enabled": true,
    "executablePath": "/usr/bin/google-chrome-stable",
    "headless": false,
    "noSandbox": true
  },
  "logging": {
    "redactSensitive": "tools"
  },
  "plugins": {
    "entries": {
      "xai": {
        "enabled": true
      },
      "browser": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "anthropic": {
        "enabled": true
      },
      "lossless-claw": {
        "enabled": true
      }
    },
    "allow": [
      "lossless-claw"
    ],
    "slots": {
      "contextEngine": "lossless-claw"
    }
  }
}
