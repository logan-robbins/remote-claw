{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "workspace": "/mnt/claw-data/workspace",
      "maxConcurrent": 32,
      "sandbox": {
        "mode": "off"
      },
      "elevatedDefault": "full",
      "thinkingDefault": "high",
      "skills": [
        "/mnt/claw-data/workspace/skills"
      ],
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "heartbeat": {
        "every": "30m"
      },
      "subagents": {
        "allowAgents": ["*"],
        "maxSpawnDepth": 5,
        "maxChildrenPerAgent": 20,
        "maxConcurrent": 32,
        "runTimeoutSeconds": 0,
        "requireAgentId": false
      },
      "models": {
        "anthropic/claude-opus-4-6": {
          "params": {
            "cacheRetention": "short"
          },
          "alias": "opus"
        }
      },
      "compaction": {
        "mode": "safeguard"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "grok-4",
            "name": "Grok 4",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 32000
          },
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 32000
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "open",
      "streaming": {
        "mode": "partial"
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "none"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowedOrigins": ["*"]
    }
  },
  "tools": {
    "profile": "full",
    "fs": {
      "workspaceOnly": false
    },
    "exec": {
      "security": "full",
      "ask": "off",
      "host": "gateway",
      "backgroundMs": 10000,
      "timeoutSec": 1800,
      "applyPatch": {
        "workspaceOnly": false
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "*": ["*"]
      }
    },
    "sessions": {
      "visibility": "all"
    },
    "web": {
      "search": {
        "enabled": true
      },
      "fetch": {
        "enabled": true
      }
    },
    "loopDetection": {
      "enabled": true,
      "historySize": 30,
      "warningThreshold": 10,
      "criticalThreshold": 20,
      "globalCircuitBreakerThreshold": 30,
      "detectors": {
        "genericRepeat": true,
        "knownPollNoProgress": true,
        "pingPong": true
      }
    }
  },
  "browser": {
    "enabled": true,
    "executablePath": "/usr/bin/google-chrome-stable",
    "headless": false,
    "noSandbox": true,
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    }
  },
  "logging": {
    "redactSensitive": "off"
  },
  "commands": {
    "useAccessGroups": false
  },
  "plugins": {
    "entries": {
      "xai": {
        "enabled": true
      },
      "browser": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "anthropic": {
        "enabled": true
      },
      "lossless-claw": {
        "enabled": true
      },
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all"
        }
      }
    },
    "allow": [
      "lossless-claw"
    ],
    "slots": {
      "contextEngine": "lossless-claw"
    }
  }
}
