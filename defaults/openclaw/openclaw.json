{
  "agents": {
    "defaults": {
      "model": {
        "primary": "xai/grok-4.20-0309-reasoning",
        "fallbacks": ["xai/grok-4"]
      },
      "workspace": "/mnt/claw-data/workspace",
      "maxConcurrent": 4,
      "sandbox": {
        "mode": "off"
      },
      "elevatedDefault": "full",
      "thinkingDefault": "max",
      "subagents": {
        "model": "xai/grok-4.20-0309-reasoning",
        "maxConcurrent": 4,
        "maxSpawnDepth": 5,
        "maxChildrenPerAgent": 20
      }
    },
    "list": [
      {
        "id": "main",
        "default": true
      }
    ]
  },

  "models": {
    "mode": "merge",
    "providers": {
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "grok-4.20-0309-reasoning",
            "name": "Grok 4 Reasoning",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 32768
          },
          {
            "id": "grok-4",
            "name": "Grok 4",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "disabled",
      "streaming": "partial"
    }
  },

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "tailscale": {
      "mode": "off"
    }
  },

  "tools": {
    "exec": {
      "security": "full",
      "ask": "off",
      "backgroundMs": 10000,
      "timeoutSec": 1800
    },
    "web": {
      "search": { "enabled": true },
      "fetch": { "enabled": true }
    }
  },

  "browser": {
    "enabled": true,
    "executablePath": "/usr/bin/google-chrome-stable",
    "headless": false,
    "noSandbox": true,
    "cdpPort": 18800
  },

  "logging": {
    "redactSensitive": "tools"
  }
}
