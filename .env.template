# Copy this file to .env and fill in your keys:
#   cp .env.template .env

# -----------------------------------------------------------------------------
# Shared secrets (used by all claws)
# -----------------------------------------------------------------------------

# Required: xAI API key from https://console.x.ai
XAI_API_KEY=xai-your-api-key-here

# -----------------------------------------------------------------------------
# Per-claw Telegram bot tokens
# -----------------------------------------------------------------------------
# Each claw needs its own Telegram bot (Telegram only allows one active
# connection per bot token). Create a bot for each claw via @BotFather, then
# set the token here.
#
# Variable naming: TELEGRAM_BOT_TOKEN_<CLAW_NAME>
#   - Claw name uppercased
#   - Hyphens converted to underscores
#
# Examples:
#   Claw "main"        -> TELEGRAM_BOT_TOKEN_MAIN
#   Claw "research"    -> TELEGRAM_BOT_TOKEN_RESEARCH
#   Claw "research-v2" -> TELEGRAM_BOT_TOKEN_RESEARCH_V2
# -----------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN_MAIN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# -----------------------------------------------------------------------------
# Per-claw Telegram user ID allowlists (optional)
# -----------------------------------------------------------------------------
# If set, only this Telegram user can message the bot. Get your numeric ID
# by messaging @userinfobot on Telegram.
#
# Leave unset for an open policy (the bot responds to anyone who messages it).
#
# Variable naming: TELEGRAM_USER_ID_<CLAW_NAME>  (same rules as above)
# -----------------------------------------------------------------------------

# TELEGRAM_USER_ID_MAIN=123456789
