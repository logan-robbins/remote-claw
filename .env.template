# Copy this file to .env and fill in your keys:
#   cp .env.template .env
#
# deploy.sh sources .env and uses envsubst to render cloud-init.yaml with your
# values before `az vm create`. .env stays on your machine and is gitignored.
# cloud-init.yaml contains ${VAR} placeholders, never the actual secrets.

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------

# Which model the agent uses. Format: provider/model-name
# Examples:
#   xai/grok-4           (requires XAI_API_KEY)
#   openai/gpt-4o        (requires OPENAI_API_KEY)
#   anthropic/claude-4    (requires ANTHROPIC_API_KEY)
OPENCLAW_MODEL=xai/grok-4.20-0309-reasoning

# -----------------------------------------------------------------------------
# Provider API keys (set whichever your model needs)
# -----------------------------------------------------------------------------

# xAI: https://console.x.ai
XAI_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Web research / data tools
# -----------------------------------------------------------------------------

# Optional: Bright Data API token from https://brightdata.com
# Used by the Bright Data MCP server for web scraping and search.
BRIGHTDATA_API_TOKEN=your-brightdata-token-here

# -----------------------------------------------------------------------------
# Telegram bot
# -----------------------------------------------------------------------------

# Required: Telegram bot token from @BotFather on Telegram.
# This is the bot you will message to talk to the agent.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# Optional: your numeric Telegram user ID. Get it by messaging @userinfobot.
# If set, only this user can message the bot (allowlist mode).
# If unset or blank, the bot responds to anyone who messages it (open mode).
TELEGRAM_USER_ID=

# -----------------------------------------------------------------------------
# Tailscale (remote gateway access)
# -----------------------------------------------------------------------------

# Optional: Tailscale auth key for unattended join.
# Generate at https://login.tailscale.com/admin/settings/keys
# If set, the VM auto-joins your tailnet at boot. Then set
# gateway.tailscale.mode to "serve" or "funnel" in openclaw.json.
TAILSCALE_AUTHKEY=

# -----------------------------------------------------------------------------
# VM access
# -----------------------------------------------------------------------------

# Optional: password for SSH and VNC access to the VM.
# This single password is used for both SSH login and VNC viewer authentication.
# If unset, deploy.sh generates a random password and prints it at deploy time.
# The active password is always saved in .vm-state after deploy.
VM_PASSWORD=
