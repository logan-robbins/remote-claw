# Copy this file to .env and fill in your keys:
#   cp .env.template .env
#
# deploy.sh sources .env and uses envsubst to render cloud-init.yaml with your
# values before `az vm create`. .env stays on your machine and is gitignored.
# cloud-init.yaml contains ${VAR} placeholders, never the actual secrets.

# -----------------------------------------------------------------------------
# Model provider keys
# -----------------------------------------------------------------------------

# Required: xAI API key from https://console.x.ai
# OpenClaw's default agent uses xAI's grok-4 model.
XAI_API_KEY=xai-your-api-key-here

# Optional: OpenAI API key from https://platform.openai.com/api-keys
# Used if you configure an agent with an OpenAI model.
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Web research / data tools
# -----------------------------------------------------------------------------

# Optional: Bright Data API token from https://brightdata.com
# Used by the Bright Data MCP server for web scraping and search.
BRIGHTDATA_API_TOKEN=your-brightdata-token-here

# -----------------------------------------------------------------------------
# Telegram bot
# -----------------------------------------------------------------------------

# Required: Telegram bot token from @BotFather on Telegram.
# This is the bot you will message to talk to the agent.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# Optional: your numeric Telegram user ID. Get it by messaging @userinfobot.
# If set, only this user can message the bot (allowlist mode).
# If unset or blank, the bot responds to anyone who messages it (open mode).
TELEGRAM_USER_ID=
